<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="farm_worker_log_list" model="ir.ui.view">
            <field name="name">farm.worker.log.list</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <list string="Worker Logs" editable="bottom">
                    <field name="date"/>
                    <field name="worker_name"/>
                    <field name="task_description"/>
                    <field name="safety_briefing" widget="boolean_fa"/>
                    <field name="wage_amount" sum="Total"/>
                    <field name="state" widget="badge" decoration-success="state == 'confirmed'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="farm_worker_log_form" model="ir.ui.view">
            <field name="name">farm.worker.log.form</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <form string="Worker Log">
                    <header>
                        <button name="action_confirm" type="object"
                                string="Confirm"
                                invisible="state == 'confirmed'"
                                class="btn-primary"/>
                        <button name="action_draft" type="object"
                                string="Reset to Draft"
                                invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="worker_name"/>
                                <field name="worker_id_number"
                                       placeholder="Optional: National ID number"/>
                            </group>
                            <group>
                                <field name="wage_amount" widget="monetary"
                                       options="{'display_currency': 'company_currency_id'}"/>
                                <field name="safety_briefing"/>
                            </group>
                        </group>
                        <group string="Work Details">
                            <field name="task_description" nolabel="1"
                                   placeholder="e.g. Harvest C1+C2, pack 10kg"/>
                            <field name="lot_ids" widget="many2many_tags"
                                   placeholder="Batches worked on today (optional)"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="farm_worker_log_search" model="ir.ui.view">
            <field name="name">farm.worker.log.search</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="worker_name"/>
                    <field name="date"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_farm_worker_log" model="ir.actions.act_window">
            <field name="name">Worker Logs</field>
            <field name="res_model">farm.worker.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="farm_worker_log_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Record daily worker activity for GAP compliance.
                </p>
                <p>
                    For new workers, include their ID number.
                    Safety briefing is recorded automatically.
                </p>
            </field>
        </record>

        <!-- Menu - top level under VivaFarm -->
        <menuitem id="menu_farm_worker_log"
                  name="Worker Logs"
                  parent="vivafarm_farm_logs.menu_farm_root"
                  action="action_farm_worker_log"
                  sequence="20"/>

    </data>
</odoo>