<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="farm_input_log_list" model="ir.ui.view">
            <field name="name">farm.input.log.list</field>
            <field name="model">farm.input.log</field>
            <field name="arch" type="xml">
                <list string="Farm Input Logs" editable="bottom">
                    <field name="date"/>
                    <field name="bench_id"/>
                    <field name="crop_id"/>
                    <field name="lot_id"/>
                    <field name="ec_value"/>
                    <field name="ph_value"/>
                    <field name="nutrient_adjustment"/>
                    <field name="acid_adjustment"/>
                    <field name="state" widget="badge" decoration-success="state == 'confirmed'"/>
                    <button name="action_confirm" type="object"
                            string="Confirm"
                            icon="fa-check"
                            invisible="state == 'confirmed'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="farm_input_log_form" model="ir.ui.view">
            <field name="name">farm.input.log.form</field>
            <field name="model">farm.input.log</field>
            <field name="arch" type="xml">
                <form string="Farm Input Log">
                    <header>
                        <button name="action_confirm" type="object"
                                string="Confirm"
                                invisible="state == 'confirmed'"
                                class="btn-primary"/>
                        <button name="action_draft" type="object"
                                string="Reset to Draft"
                                invisible="state == 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="bench_id"/>
                                <field name="lot_id"/>
                                <field name="crop_id"/>
                            </group>
                            <group>
                                <field name="ec_value"/>
                                <field name="ph_value"/>
                                <field name="nutrient_adjustment"/>
                                <field name="acid_adjustment"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="farm_input_log_search" model="ir.ui.view">
            <field name="name">farm.input.log.search</field>
            <field name="model">farm.input.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="date"/>
                    <field name="bench_id"/>
                    <field name="lot_id"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_farm_input_log" model="ir.actions.act_window">
            <field name="name">Farm Input Logs</field>
            <field name="res_model">farm.input.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="farm_input_log_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Record daily EC/pH readings for each bench.
                </p>
                <p>
                    Create one log entry per bench per day with EC and pH readings.
                    Optional: log nutrient or acid adjustments.
                </p>
            </field>
        </record>

        <!-- Menu - top level under Hydroponic -->
        <menuitem id="menu_farm_root" name="Hydroponic"
                  sequence="90" web_icon="stock,static/description/icon.png"/>
        <menuitem id="menu_farm_input_log"
                  name="Input Logs (EC/pH)"
                  parent="menu_farm_root"
                  action="action_farm_input_log"
                  sequence="20"/>

    </data>
</odoo>