<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vivafarm_petty_cash_voucher_form" model="ir.ui.view">
        <field name="name">vivafarm.petty.cash.voucher.form</field>
        <field name="model">vivafarm.petty.cash.voucher</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Voucher">
                <header>
                    <button name="action_submit" type="object"
                            string="Submit" class="btn-primary"
                            invisible="state != 'draft'" icon="fa-check"/>
                    <button name="action_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'" icon="fa-undo"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state not in ('draft','submitted')" icon="fa-times"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_id"/>
                            <field name="date"/>
                            <field name="payee"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="expense_account_id"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="What was this cash for?"/>
                        <field name="receipt_attached" decoration-danger="amount &gt; 1000 and not receipt_attached"/>
                    </group>
                    <group>
                        <field name="journal_entry_id" readonly="1" invisible="not journal_entry_id"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_vivafarm_petty_cash_voucher_tree" model="ir.ui.view">
        <field name="name">vivafarm.petty.cash.voucher.tree</field>
        <field name="model">vivafarm.petty.cash.voucher</field>
        <field name="arch" type="xml">
            <list string="Petty Cash Vouchers"
                  decoration-info="state=='draft'"
                  decoration-warning="state=='submitted'"
                  decoration-success="state=='reconciled'"
                  decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="fund_id"/>
                <field name="payee"/>
                <field name="description"/>
                <field name="amount" widget="monetary"/>
                <field name="expense_account_id"/>
                <field name="receipt_attached" widget="boolean_toggle"/>
                <field name="state" widget="badge" decoration-bf="state=='reconciled'"/>
            </list>
        </field>
    </record>

    <record id="action_vivafarm_petty_cash_voucher" model="ir.actions.act_window">
        <field name="name">Petty Cash Vouchers</field>
        <field name="res_model">vivafarm.petty.cash.voucher</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
