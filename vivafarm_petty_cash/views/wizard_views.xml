<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="view_vivafarm_petty_cash_topup_wizard_form" model="ir.ui.view">
        <field name="name">vivafarm.petty.cash.topup.form</field>
        <field name="model">vivafarm.petty.cash.topup</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Top-Up">
                <group>
                    <field name="fund_id"/>
                    <field name="date"/>
                    <field name="amount"/>
                    <field name="journal_id"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Top-Up" class="btn-primary"
                            icon="fa-check"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vivafarm_petty_cash_topup" model="ir.actions.act_window">
        <field name="name">Petty Cash Top-Up</field>
        <field name="res_model">vivafarm.petty.cash.topup</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_vivafarm_petty_cash_replenish_wizard_form" model="ir.ui.view">
        <field name="name">vivafarm.petty.cash.replenish.form</field>
        <field name="model">vivafarm.petty.cash.replenish</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Replenishment">
                <group>
                    <group>
                        <field name="fund_id"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="currency_id" invisible="1"/>
                        <field name="total_disbursed" readonly="1"/>
                        <field name="expected_balance" readonly="1"/>
                        <field name="counted_balance"/>
                        <field name="variance" readonly="1"/>
                    </group>
                </group>
                <field name="voucher_ids" widget="many2many"
                       options="{'no_create': True}"/>
                <footer>
                    <button name="action_confirm" type="object"
                            string="Confirm Replenishment" class="btn-primary"
                            icon="fa-check"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vivafarm_petty_cash_replenish" model="ir.actions.act_window">
        <field name="name">Petty Cash Replenishment</field>
        <field name="res_model">vivafarm.petty.cash.replenish</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    </data>
</odoo>
