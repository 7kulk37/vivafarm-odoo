<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="farm_worker_log_list" model="ir.ui.view">
            <field name="name">farm.worker.log.list</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <list string="Worker Logs" editable="bottom" multi_edit="1">
                    <field name="ref"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'confirmed'"
                           decoration-danger="state == 'canceled'"/>
                    <field name="auto_recalculation_enabled" widget="boolean_toggle" readonly="1" optional="show"/>
                    <field name="date"/>
                    <field name="worker_name"/>
                    <field name="task_description"/>
                    <field name="safety_briefing" widget="boolean_fa"/>
                    <field name="wage_amount" sum="Total"/>
                    <field name="working_hours" sum="Total"/>
                    <button name="action_confirm" type="object"
                            string="Confirm"
                            icon="fa-check"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            icon="fa-times"
                            invisible="state != 'confirmed'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="farm_worker_log_form" model="ir.ui.view">
            <field name="name">farm.worker.log.form</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <form string="Worker Log">
                    <header>
                        <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_cancel" type="object" string="Cancel" invisible="state != 'confirmed'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ref" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date"/>
                                <field name="worker_name"/>
                                <field name="worker_id_number"/>
                                <field name="working_hours"/>
                                <field name="wage_amount"/>
                            </group>
                            <group>
                                <field name="safety_briefing"/>
                                <field name="auto_recalculation_enabled" readonly="1"/>
                                <field name="lot_ids" widget="many2many_tags"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                        </group>
                        <field name="task_description" placeholder="What work was done today?"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Server Actions (bulk) -->
        <record id="action_farm_worker_log_confirm" model="ir.actions.server">
            <field name="name">Confirm</field>
            <field name="model_id" ref="model_farm_worker_log"/>
            <field name="binding_model_id" ref="model_farm_worker_log"/>
            <field name="state">code</field>
            <field name="code">
                records.action_confirm()
            </field>
        </record>

        <record id="action_farm_worker_log_cancel" model="ir.actions.server">
            <field name="name">Cancel</field>
            <field name="model_id" ref="model_farm_worker_log"/>
            <field name="binding_model_id" ref="model_farm_worker_log"/>
            <field name="state">code</field>
            <field name="code">
                records.action_cancel()
            </field>
        </record>

        <record id="action_farm_worker_log_recalc" model="ir.actions.server">
            <field name="name">Recalculate Direct Labor Rate</field>
            <field name="model_id" ref="model_farm_worker_log"/>
            <field name="binding_model_id" ref="model_farm_worker_log"/>
            <field name="state">code</field>
            <field name="code">
                records.action_recalculate_direct_labor_rate()
            </field>
        </record>

        <record id="action_farm_worker_log_enable_auto" model="ir.actions.server">
            <field name="name">Enable Auto Recalculation</field>
            <field name="model_id" ref="model_farm_worker_log"/>
            <field name="binding_model_id" ref="model_farm_worker_log"/>
            <field name="state">code</field>
            <field name="code">
                records.action_enable_auto_recalculation()
            </field>
        </record>

        <record id="action_farm_worker_log_disable_auto" model="ir.actions.server">
            <field name="name">Disable Auto Recalculation</field>
            <field name="model_id" ref="model_farm_worker_log"/>
            <field name="binding_model_id" ref="model_farm_worker_log"/>
            <field name="state">code</field>
            <field name="code">
                records.action_disable_auto_recalculation()
            </field>
        </record>

        <!-- Search View -->
        <record id="farm_worker_log_search" model="ir.ui.view">
            <field name="name">farm.worker.log.search</field>
            <field name="model">farm.worker.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="worker_name"/>
                    <field name="date"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_farm_worker_log" model="ir.actions.act_window">
            <field name="name">Worker Logs</field>
            <field name="res_model">farm.worker.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="farm_worker_log_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Record daily worker activity for GAP compliance.
                </p>
                <p>
                    For new workers, include their ID number.
                    Safety briefing is recorded automatically.
                </p>
            </field>
        </record>

        <!-- Menu - top level under Hydroponic -->
        <menuitem id="menu_farm_worker_log"
                  name="Worker Logs"
                  parent="menu_farm_root"
                  action="action_farm_worker_log"
                  sequence="30"/>

    </data>
</odoo>