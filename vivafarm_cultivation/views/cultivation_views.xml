<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="vivafarm_cultivation_list" model="ir.ui.view">
            <field name="name">vivafarm.cultivation.list</field>
            <field name="model">vivafarm.cultivation</field>
            <field name="arch" type="xml">
                <list string="Cultivation" default_order="id desc">
                    <field name="name"/>
                    <field name="state" widget="badge"/>
                    <field name="plant_date"/>
                    <field name="target_transplant_date"/>
                    <field name="target_harvest_date"/>
                    <field name="seed_lot_id"/>
                    <field name="crop_id"/>
                    <field name="nursery_id"/>
                    <field name="bench_id"/>
                    <field name="live_lot_name"/>
                    <field name="harvest_date"/>
                    <field name="packed_lot_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="vivafarm_cultivation_form" model="ir.ui.view">
            <field name="name">vivafarm.cultivation.form</field>
            <field name="model">vivafarm.cultivation</field>
            <field name="arch" type="xml">
                <form string="Cultivation">
                    <header>
                        <button name="action_germinate" string="Germinate" type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"
                                confirm="Germinate? This will consume seeds and create live plants."/>
                        <button name="action_grow" string="Move to Bench" type="object"
                                class="btn-primary"
                                invisible="state != 'germinated'"/>
                        <button name="action_harvest" string="Harvest" type="object"
                                class="btn-primary"
                                invisible="state != 'transplanted'"/>
                        <button name="action_done" string="Mark Done" type="object"
                                class="btn-success"
                                invisible="state != 'harvested'"
                                confirm="Mark Done? This will move packed goods to WH/Stock and spoilage to Spoilage."/>
                        <button name="action_cancel" string="Cancel" type="object"
                                class="btn-secondary"
                                invisible="state in ('done', 'canceled')"
                                confirm="Cancel this cultivation? Seeds will be returned if already germinated."/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,germinated,transplanted,harvested,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1" invisible="state == 'draft'"/></h1>
                        </div>
                        <group>
                            <group string="Information">
                                <field name="recipe_id"
                                       options="{'no_create': True}"
                                       readonly="state != 'draft'"
                                       placeholder="Select recipe to auto-fill..."/>
                                <field name="seed_product_id"/>
                                <field name="nutrient_product_id" readonly="1"/>
                                <field name="acid_product_id" readonly="1"/>
                                <field name="crop_id" readonly="1"/>
                                <field name="packed_product_id" readonly="1"/>
                            </group>
                            <group string="Germinate">
                                <field name="plant_date" readonly="state != 'draft'"/>
                                <field name="seed_lot_id"
                                       options="{'no_create': True}"
                                       readonly="state != 'draft'"
                                       domain="[('product_id.name', 'ilike', 'Seeds -')]"/>
                                <field name="grams_to_sow" readonly="1"/>
                                <field name="target_plant_count"
                                       readonly="state not in ('draft', 'germinated')"/>
                                <field name="nursery_id" readonly="1"/>
                                <field name="live_lot_name" invisible="state == 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <group string="Transplant">
                                <field name="target_transplant_date" readonly="1"/>
                                <field name="bench_id"
                                       readonly="state not in ('draft', 'germinated')"/>
                                <field name="transplanted_date"
                                       readonly="state not in ('draft', 'germinated')"/>
                                <field name="transplant_amount"
                                       readonly="state not in ('draft', 'germinated')"/>
                            </group>
                            <group string="Harvest">
                                <field name="target_harvest_date"/>
                                <field name="harvest_date"
                                       readonly="state not in ('transplanted', 'harvested')"/>
                                <field name="packed_kg"
                                       readonly="state not in ('transplanted', 'harvested')"/>
                                <field name="spoilage_units"
                                       readonly="state not in ('transplanted', 'harvested')"/>
                            </group>
                        </group>
                        <group>
                            <group string="Timeline" invisible="state == 'draft'">
                                <field name="germinated_date"/>
                                <field name="growing_date"/>
                                <field name="harvested_date"/>
                                <field name="done_date" invisible="state != 'done'"/>
                                <field name="canceled_date" invisible="state != 'canceled'"/>
                            </group>
                            <group string="Summary" invisible="state == 'draft'">
                                <field name="packed_lot_id" invisible="state != 'done'"/>
                                <field name="packed_kg" string="Harvest Kg" readonly="1"/>
                                <field name="grams_consumed" invisible="state == 'draft'"/>
                                <field name="total_nutrient_consumed" invisible="state == 'draft'"/>
                                <field name="total_acid_consumed" invisible="state == 'draft'"/>
                                <field name="plant_picking_id"/>
                                <field name="harvest_picking_id" invisible="state in ('draft', 'germinated', 'transplanted')"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1"
                                   placeholder="Log observations that vary from recipe..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Menu Action -->
        <record id="action_vivafarm_cultivation" model="ir.actions.act_window">
            <field name="name">Cultivation</field>
            <field name="res_model">vivafarm.cultivation</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item - top level under VivaFarm -->
        <menuitem id="menu_vivafarm_cultivation"
                  name="Cultivation"
                  parent="vivafarm_farm_logs.menu_farm_root"
                  action="action_vivafarm_cultivation"
                  sequence="5"/>
    </data>
</odoo>
