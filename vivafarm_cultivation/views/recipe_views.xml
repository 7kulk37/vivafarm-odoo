<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="vivafarm_recipe_list" model="ir.ui.view">
            <field name="name">vivafarm.recipe.list</field>
            <field name="model">vivafarm.recipe</field>
            <field name="arch" type="xml">
                <list string="Crop recipes" default_order="name asc">
                    <field name="name"/>
                    <field name="seed_product_id"/>
                    <field name="crop_id"/>
                    <field name="packed_product_id"/>
                    <field name="grams_to_sow"/>
                    <field name="target_plant_count"/>
                    <field name="transplant_amount"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="vivafarm_recipe_form" model="ir.ui.view">
            <field name="name">vivafarm.recipe.form</field>
            <field name="model">vivafarm.recipe</field>
            <field name="arch" type="xml">
                <form string="Recipe">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="e.g. Green Oak Standard"/></h1>
                        </div>
                        <group>
                            <group string="Products">
                                <field name="seed_product_id" options="{'no_create': True}"/>
                                <field name="crop_id" options="{'no_create': True}"/>
                                <field name="packed_product_id" options="{'no_create': True}"/>
                                <field name="nutrient_product_id" options="{'no_create': True}"/>
                                <field name="acid_product_id" options="{'no_create': True}"/>
                            </group>
                            <group string="Defaults">
                                <field name="grams_to_sow"/>
                                <field name="target_plant_count"/>
                                <field name="transplant_amount"/>
                                <field name="germinate_duration"/>
                                <field name="total_grow_duration"/>
                                <field name="nursery_id" options="{'no_create': True}"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" nolabel="1" placeholder="Notes about this recipe..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="vivafarm_recipe_search" model="ir.ui.view">
            <field name="name">vivafarm.recipe.search</field>
            <field name="model">vivafarm.recipe</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="crop_id"/>
                    <field name="active"/>
                </search>
            </field>
        </record>

        <record id="action_vivafarm_recipe" model="ir.actions.act_window">
            <field name="name">Crop recipes</field>
            <field name="res_model">vivafarm.recipe</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"active_test": False}</field>
            <field name="search_view_id" ref="vivafarm_recipe_search"/>
        </record>

        <menuitem id="menu_vivafarm_recipe"
                  name="Crop recipes"
                  parent="menu_farm_root"
                  action="action_vivafarm_recipe"
                  sequence="40"/>

    </data>
</odoo>
