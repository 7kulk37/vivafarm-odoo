<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="farm_location_list" model="ir.ui.view">
            <field name="name">farm.location.list</field>
            <field name="model">farm.location</field>
            <field name="arch" type="xml">
                <list string="Location Recipes" editable="bottom">
                    <field name="name"/>
                    <field name="location_type"/>
                    <field name="active" widget="boolean_toggle"/>
                    <field name="notes"/>
                </list>
            </field>
        </record>

        <record id="farm_location_form" model="ir.ui.view">
            <field name="name">farm.location.form</field>
            <field name="model">farm.location</field>
            <field name="arch" type="xml">
                <form string="Location Recipe">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="location_type"/>
                            <field name="active"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_farm_location" model="ir.actions.act_window">
            <field name="name">Location Recipes</field>
            <field name="res_model">farm.location</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_farm_location"
                  name="Location Recipes"
                  parent="menu_farm_root"
                  action="action_farm_location"
                  sequence="39"/>

    </data>
</odoo>
